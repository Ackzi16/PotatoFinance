FROM python:3.11-slim

WORKDIR /app

COPY tools/requirements-bridge.txt /app/requirements-bridge.txt
RUN pip install --no-cache-dir -r /app/requirements-bridge.txt

COPY tools/monopoly_bridge.py /app/monopoly_bridge.py

ENV BRIDGE_ALLOWED_ORIGINS=*
ENV MAX_FILE_MB=15

EXPOSE 8765
CMD ["uvicorn", "monopoly_bridge:app", "--host", "0.0.0.0", "--port", "8765"]
